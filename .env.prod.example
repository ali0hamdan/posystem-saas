# Copy to .env and fill in all values before running docker compose -f docker-compose.prod.yml up

# --- Database ---
POSTGRES_USER=posuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pos

# --- API ---
JWT_SECRET=CHANGE_ME_48_RANDOM_CHARS_MINIMUM
JWT_EXPIRES_IN=15m
SAAS_JWT_SECRET=CHANGE_ME_DIFFERENT_48_RANDOM_CHARS
CORS_ORIGIN=https://yourdomain.com
API_PORT=3000

# --- SaaS Admin (seeded on first run) ---
SAAS_ADMIN_EMAIL=super@yourdomain.com
SAAS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- License (generate with: cd backend && npm run license:keys) ---
LICENSE_RSA_PRIVATE_KEY_B64=
LICENSE_RSA_PUBLIC_KEY_B64=
BYPASS_LICENSE=false

# --- Frontend ---
VITE_API_URL=https://yourdomain.com/api
VITE_BYPASS_LICENSE=false
WEB_PORT=80

# --- Monitoring (optional) ---
SENTRY_DSN=
LOG_LEVEL=info
