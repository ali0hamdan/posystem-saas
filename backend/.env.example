# Copy to `.env` and adjust. Never commit `.env`.

# --- Core ---
NODE_ENV=development
# HTTP port (Nest listens here)
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pos?schema=public

# --- Security: JWT ---
# Development: at least 32 characters. Production: at least 48, cryptographically random (see README).
JWT_SECRET=0123456789abcdef0123456789abcdef
JWT_EXPIRES_IN=8h

# --- CORS ---
# Comma-separated browser origins allowed to call the API (no trailing slashes).
# Use `*` only in local development. In production, set explicit origins (Joi rejects `*` when NODE_ENV=production).
CORS_ORIGIN=http://localhost:5173

# --- Reverse proxy / rate limiting ---
# Set to `1` or `true` when the API sits behind a reverse proxy so client IP and rate limits are correct.
# Defaults to `false` in development when unset; defaults to `true` in production when unset.
# TRUST_PROXY=false

# Global rate limit (requests per IP per window). Login is further limited to 5/min per IP.
# THROTTLE_TTL_MS=60000
# Development default is high; production default is 200/window unless overridden.
# THROTTLE_LIMIT=10000

# --- Seed (optional) ---
# Required when NODE_ENV=production (see prisma/seed.ts).
# SEED_ADMIN_PASSWORD=

# Platform super-admin (prisma db seed upserts SaaSAdmin; used by POST /saas/auth/login)
# SAAS_ADMIN_EMAIL=super@example.com
# SAAS_ADMIN_PASSWORD=change-me-in-production

# --- SaaS Super Admin URL hardening ---
# Reachable only at /${SAAS_ADMIN_API_PREFIX}/* (instead of the default /saas/*).
# Letters, digits, hyphens, underscores only — no slashes. Single path segment.
# When set, the default /saas/* path also returns 404.
# Auth + role guards remain in place regardless of this prefix.
# SAAS_ADMIN_API_PREFIX=saas-admin-api-8f3k

# --- Billing (development) ---
# Enables POST /public/payments/:id/simulate-success so local dev can complete
# the checkout flow without a real payment gateway. MUST stay unset / false in
# production and on every staging/preview environment — staging is not
# production-NODE_ENV but staging must NOT activate subscriptions for free.
# ENABLE_PAYMENT_SIMULATION=true

# --- Licensing (RS256 license tokens; separate from JWT_SECRET) ---
# Production: BYPASS_LICENSE must be false and both RSA keys below are required (valid base64 PEM).
# Development: run `npm run license:keys` in the backend folder, paste the output here, restart the API.
# BYPASS_LICENSE=false
# LICENSE_RSA_PRIVATE_KEY_B64=
# LICENSE_RSA_PUBLIC_KEY_B64=
# Optional: cache successful license validation (ms).
# LICENSE_VALIDATION_CACHE_MS=45000

# --- Monitoring (optional) ---
# Sentry DSN for the API process (leave unset to disable).
# SENTRY_DSN=
# Pino log level: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info
