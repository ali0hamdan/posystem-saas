model CustomerOverdueNotificationLog {
  id               String           @id @default(uuid())
  clientId         String
  customerId       String
  /// e.g. SALE (official invoice / retail credit sale)
  sourceType       String           @db.VarChar(32)
  sourceId         String
  notificationType NotificationType @default(CUSTOMER_OVERDUE)
  sentAt           DateTime         @default(now())

  @@unique([clientId, sourceType, sourceId, notificationType])
  @@index([clientId])
  @@index([customerId])
  @@index([sourceType, sourceId])
}

model OtpCode {
  id          String     @id @default(cuid())
  clientId    String?
  userId      String?
  email       String
  codeHash    String
  purpose     OtpPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([email, purpose])
  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
