// ===========================================================================
// Food & Beverage (F&B) module  — additive, tenant-scoped by clientId/branchId.
// References to existing entities (products, customers, sales, users) are kept
// as validated ids rather than relations, so no existing model is modified.
// ===========================================================================

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum FnbOrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum FnbOrderStatus {
  OPEN
  SENT
  READY
  SERVED
  COMPLETED
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
}

enum FnbOrderItemStatus {
  PENDING
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenTicketStatus {
  QUEUED
  PREPARING
  READY
  BUMPED
  RECALLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model DiningArea {
  id        String   @id @default(uuid())
  clientId  String
  branchId  String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables RestaurantTable[]

  @@index([clientId])
  @@index([branchId])
}

model RestaurantTable {
  id           String      @id @default(uuid())
  clientId     String
  branchId     String
  diningAreaId String?
  label        String
  seats        Int         @default(2)
  status       TableStatus @default(AVAILABLE)
  posX         Int?
  posY         Int?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  diningArea   DiningArea?   @relation(fields: [diningAreaId], references: [id], onDelete: SetNull)
  orders       FnbOrder[]
  reservations Reservation[]

  @@unique([clientId, branchId, label])
  @@index([clientId])
  @@index([branchId])
  @@index([status])
}

model MenuItem {
  id          String   @id @default(uuid())
  clientId    String
  categoryId  String?
  productId   String?
  name        String
  description String?
  price       Decimal  @db.Decimal(14, 2)
  imageUrl    String?
  prepStation String?  @default("KITCHEN")
  isAvailable Boolean  @default(true)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modifierGroups MenuItemModifierGroup[]
  orderItems     FnbOrderItem[]
  recipe         Recipe?

  @@index([clientId])
  @@index([categoryId])
  @@index([isActive])
}

model ModifierGroup {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifiers Modifier[]
  menuItems MenuItemModifierGroup[]

  @@index([clientId])
}

model Modifier {
  id         String  @id @default(uuid())
  clientId   String
  groupId    String
  name       String
  priceDelta Decimal @default(0) @db.Decimal(14, 2)
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([groupId])
}

model MenuItemModifierGroup {
  menuItemId      String
  modifierGroupId String
  sortOrder       Int    @default(0)

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, modifierGroupId])
  @@index([modifierGroupId])
}

model FnbOrder {
  id            String         @id @default(uuid())
  clientId      String
  branchId      String
  orderNumber   String
  type          FnbOrderType   @default(DINE_IN)
  status        FnbOrderStatus @default(OPEN)
  tableId       String?
  customerId    String?
  serverId      String
  guestCount    Int            @default(1)
  saleId        String?
  notes           String?
  deliveryAddress String?
  deliveryPhone   String?
  driverName      String?
  subtotal      Decimal        @default(0) @db.Decimal(14, 2)
  discountTotal Decimal        @default(0) @db.Decimal(14, 2)
  taxTotal      Decimal        @default(0) @db.Decimal(14, 2)
  total         Decimal        @default(0) @db.Decimal(14, 2)
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  table          RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items          FnbOrderItem[]
  kitchenTickets KitchenTicket[]
  refunds        Refund[]

  @@unique([clientId, orderNumber])
  @@index([clientId])
  @@index([branchId])
  @@index([status])
  @@index([tableId])
}

model FnbOrderItem {
  id             String             @id @default(uuid())
  clientId       String
  orderId        String
  menuItemId     String?
  name           String
  quantity       Int                @default(1)
  unitPrice      Decimal            @db.Decimal(14, 2)
  modifiersTotal Decimal            @default(0) @db.Decimal(14, 2)
  lineTotal      Decimal            @db.Decimal(14, 2)
  status         FnbOrderItemStatus @default(PENDING)
  notes          String?
  sentAt         DateTime?
  createdAt      DateTime           @default(now())

  order              FnbOrder               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem           MenuItem?              @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  modifiers          FnbOrderItemModifier[]
  kitchenTicketItems KitchenTicketItem[]
  refundItems        RefundItem[]

  @@index([orderId])
  @@index([clientId])
}

model FnbOrderItemModifier {
  id          String  @id @default(uuid())
  orderItemId String
  modifierId  String?
  name        String
  priceDelta  Decimal @default(0) @db.Decimal(14, 2)

  orderItem FnbOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model KitchenTicket {
  id           String              @id @default(uuid())
  clientId     String
  branchId     String
  orderId      String
  ticketNumber String
  station      String?             @default("KITCHEN")
  status       KitchenTicketStatus @default(QUEUED)
  createdAt    DateTime            @default(now())
  bumpedAt     DateTime?

  order FnbOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items KitchenTicketItem[]

  @@index([clientId])
  @@index([branchId])
  @@index([orderId])
  @@index([status])
}

model KitchenTicketItem {
  id          String             @id @default(uuid())
  ticketId    String
  orderItemId String
  name        String
  quantity    Int                @default(1)
  status      FnbOrderItemStatus @default(SENT)

  ticket    KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  orderItem FnbOrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([orderItemId])
}

model Reservation {
  id            String            @id @default(uuid())
  clientId      String
  branchId      String
  tableId       String?
  customerName  String
  customerPhone String?
  partySize     Int               @default(2)
  reservedAt    DateTime
  durationMin   Int               @default(90)
  status        ReservationStatus @default(PENDING)
  notes         String?
  createdById   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  table RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([branchId])
  @@index([reservedAt])
  @@index([status])
}

model Recipe {
  id         String   @id @default(uuid())
  clientId   String
  menuItemId String   @unique
  yieldQty   Int      @default(1)
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@index([clientId])
}

model RecipeIngredient {
  id        String  @id @default(uuid())
  recipeId  String
  productId String
  quantity  Decimal @db.Decimal(14, 3)
  unit      String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// F&B operations (additive — no existing model modified). References to
// User/Branch/Product/MenuItem/FnbOrder are kept as validated ids per the
// established F&B convention, so adding these models does not change the
// relation list of any prior model.
// ---------------------------------------------------------------------------

enum WasteType {
  INGREDIENT
  MENU_ITEM
  PRODUCT
}

enum WasteReason {
  EXPIRED
  DAMAGED
  SPILL
  PREP_ERROR
  CUSTOMER_RETURN
  OTHER
}

enum DeliveryAssignmentStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
  CANCELLED
}

enum IngredientMovementType {
  PURCHASE
  RECIPE_CONSUME
  WASTE
  ADJUSTMENT
}

model Waste {
  id            String      @id @default(uuid())
  clientId      String
  branchId      String
  type          WasteType
  reason        WasteReason
  productId     String?
  menuItemId    String?
  quantity      Decimal     @db.Decimal(14, 3)
  unit          String?
  estimatedCost Decimal     @default(0) @db.Decimal(14, 2)
  note          String?
  createdById   String
  createdAt     DateTime    @default(now())

  @@index([clientId])
  @@index([branchId])
  @@index([createdAt])
  @@index([type])
}

model DeliveryAssignment {
  id            String                   @id @default(uuid())
  clientId      String
  branchId      String
  orderId       String                   @unique
  driverId      String?
  driverName    String?
  driverPhone   String?
  status        DeliveryAssignmentStatus @default(PENDING)
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  failureReason String?
  createdById   String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([clientId])
  @@index([branchId])
  @@index([status])
  @@index([driverId])
  @@index([createdAt])
}

model IngredientMovement {
  id             String                 @id @default(uuid())
  clientId       String
  branchId       String
  productId      String
  type           IngredientMovementType
  quantityChange Decimal                @db.Decimal(14, 3)
  unit           String?
  referenceType  String?
  referenceId    String?
  note           String?
  createdById    String
  createdAt      DateTime               @default(now())

  @@index([clientId])
  @@index([branchId])
  @@index([productId])
  @@index([createdAt])
  @@index([type])
}

// ===========================================================================
// B2B document workflow — Quotation, Proforma Invoice, Stock Reservation.
// Additive: existing Sale logic is untouched. Sale gains two optional back-
// reference columns (`sourceQuotationId`, `sourceProformaId`) added below.
// All linkage between docs is stored as validated ids (no Prisma relation
// chains) to keep the existing Sale model unchanged.
// ===========================================================================

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED_TO_PROFORMA
  CONVERTED_TO_INVOICE
  CANCELLED
}

enum ProformaInvoiceStatus {
  DRAFT
  SENT
  APPROVED
  CANCELLED
  CONVERTED_TO_INVOICE
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONVERTED
  EXPIRED
}

enum StockReservationSource {
  QUOTATION
  PROFORMA
}

enum DocumentCounterType {
  QUOTATION
  PROFORMA_INVOICE
  SALE_INVOICE
  DELIVERY_NOTE
  REFUND
}

enum DeliveryNoteStatus {
  DRAFT
  SENT
  DELIVERED
  CANCELLED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalEntityType {
  QUOTATION
  PROFORMA_INVOICE
  INVOICE
  DELIVERY_NOTE
}

/// Atomic per-client document number generator. One row per (client, docType).
model DocumentCounter {
  clientId   String
  docType    DocumentCounterType
  lastNumber Int                 @default(0)
  updatedAt  DateTime            @updatedAt

  @@id([clientId, docType])
}

model Quotation {
  id                    String          @id @default(uuid())
  clientId              String
  branchId              String
  customerId            String?
  quotationNumber       String
  status                QuotationStatus @default(DRAFT)
  validUntil            DateTime?
  subtotal              Decimal         @default(0) @db.Decimal(14, 2)
  discountTotal         Decimal         @default(0) @db.Decimal(14, 2)
  taxTotal              Decimal         @default(0) @db.Decimal(14, 2)
  total                 Decimal         @default(0) @db.Decimal(14, 2)
  notes                 String?         @db.Text
  terms                 String?         @db.Text
  createdById           String
  convertedToProformaId String?
  convertedToInvoiceId  String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  items QuotationItem[]

  @@unique([clientId, quotationNumber])
  @@index([clientId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([validUntil])
}

model QuotationItem {
  id                  String   @id @default(uuid())
  clientId            String
  quotationId         String
  productId           String
  productNameSnapshot String
  skuSnapshot         String?
  barcodeSnapshot     String?
  quantity            Int
  unitPrice           Decimal  @db.Decimal(14, 2)
  discount            Decimal  @default(0) @db.Decimal(14, 2)
  taxRate             Decimal? @db.Decimal(8, 4)
  total               Decimal  @db.Decimal(14, 2)
  notes               String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([clientId])
  @@index([productId])
}

model ProformaInvoice {
  id                   String                @id @default(uuid())
  clientId             String
  branchId             String
  customerId           String?
  quotationId          String?
  proformaNumber       String
  status               ProformaInvoiceStatus @default(DRAFT)
  validUntil           DateTime?
  subtotal             Decimal               @default(0) @db.Decimal(14, 2)
  discountTotal        Decimal               @default(0) @db.Decimal(14, 2)
  taxTotal             Decimal               @default(0) @db.Decimal(14, 2)
  total                Decimal               @default(0) @db.Decimal(14, 2)
  notes                String?               @db.Text
  terms                String?               @db.Text
  reserveStock         Boolean               @default(false)
  createdById          String
  convertedToInvoiceId String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  items ProformaInvoiceItem[]

  @@unique([clientId, proformaNumber])
  @@index([clientId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([quotationId])
  @@index([createdAt])
}

model ProformaInvoiceItem {
  id                  String   @id @default(uuid())
  clientId            String
  proformaInvoiceId   String
  productId           String
  productNameSnapshot String
  skuSnapshot         String?
  barcodeSnapshot     String?
  quantity            Int
  unitPrice           Decimal  @db.Decimal(14, 2)
  discount            Decimal  @default(0) @db.Decimal(14, 2)
  taxRate             Decimal? @db.Decimal(8, 4)
  total               Decimal  @db.Decimal(14, 2)
  notes               String?

  proforma ProformaInvoice @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)

  @@index([proformaInvoiceId])
  @@index([clientId])
  @@index([productId])
}

model StockReservation {
  id          String                 @id @default(uuid())
  clientId    String
  branchId    String
  productId   String
  customerId  String?
  sourceType  StockReservationSource
  sourceId    String
  quantity    Int
  status      StockReservationStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([clientId])
  @@index([branchId])
  @@index([productId])
  @@index([sourceType, sourceId])
  @@index([status])
}

model CustomerCreditProfile {
  id               String   @id @default(uuid())
  clientId         String
  customerId       String   @unique
  creditLimit      Decimal  @default(0) @db.Decimal(14, 2)
  paymentTermsDays Int      @default(0)
  isCreditAllowed  Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model PriceList {
  id          String   @id @default(uuid())
  clientId    String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items     PriceListItem[]
  customers CustomerPriceList[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([isActive])
}

model PriceListItem {
  id          String   @id @default(uuid())
  clientId    String
  priceListId String
  productId   String
  minQuantity Int      @default(1)
  maxQuantity Int?
  unitPrice   Decimal  @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId, minQuantity])
  @@index([clientId])
  @@index([productId])
}

model CustomerPriceList {
  id          String   @id @default(uuid())
  clientId    String
  customerId  String
  priceListId String
  createdAt   DateTime @default(now())

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([clientId, customerId])
  @@index([priceListId])
}

model DeliveryNote {
  id                 String             @id @default(uuid())
  clientId           String
  branchId           String
  customerId         String
  saleId             String?
  proformaInvoiceId  String?
  deliveryNoteNumber String
  status             DeliveryNoteStatus @default(DRAFT)
  driverName         String?
  vehicleNumber      String?
  deliveryAddress    String?            @db.Text
  notes              String?            @db.Text
  deliveredAt        DateTime?
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  items DeliveryNoteItem[]

  @@unique([clientId, deliveryNoteNumber])
  @@index([clientId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([saleId])
  @@index([proformaInvoiceId])
}

model DeliveryNoteItem {
  id                  String  @id @default(uuid())
  clientId            String
  deliveryNoteId      String
  productId           String
  productNameSnapshot String
  quantity            Int
  notes               String?

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([deliveryNoteId])
  @@index([clientId])
  @@index([productId])
}

model ApprovalRequest {
  id            String                @id @default(uuid())
  clientId      String
  entityType    ApprovalEntityType
  entityId      String
  action        String                @db.VarChar(64)
  status        ApprovalRequestStatus @default(PENDING)
  requestedById String
  approvedById  String?
  reason        String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedById])
}
