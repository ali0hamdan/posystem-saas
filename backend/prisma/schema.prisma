}

model NotificationPreference {
  id                    String           @id @default(uuid())
  clientId              String
  notificationType      NotificationType
  enabled               Boolean          @default(true)
  sendToOwner           Boolean          @default(true)
  sendToGeneralManager  Boolean          @default(true)
  sendToCoManager       Boolean          @default(false)
