  updatedAt      DateTime   @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([isActive])
  @@index([expiresAt])
}

model StoreSettings {
