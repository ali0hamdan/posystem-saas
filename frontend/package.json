{
  "name": "nezhin-pos",
  "description": "Nezhin POS desktop application",
  "author": "Nezhin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons:ico": "node scripts/generate-icon.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:dev:full": "cross-env DESKTOP_LOCAL_SERVICES=true concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=true tsc -b && cross-env ELECTRON_BUILD=true vite build",
    "electron:pack": "npm run electron:build && node scripts/run-electron-builder.mjs --dir",
    "electron:dist:win": "npm run desktop:prepare && npm run desktop:preflight && node scripts/run-electron-builder.mjs --win --x64",
    "electron:dist:mac": "npm run desktop:prepare && npm run desktop:preflight && node scripts/run-electron-builder.mjs --mac",
    "electron:dist:linux": "npm run desktop:prepare && npm run desktop:preflight && node scripts/run-electron-builder.mjs --linux",
    "electron:dist": "npm run desktop:prepare && npm run desktop:preflight && node scripts/run-electron-builder.mjs --win --x64",
    "desktop:build:frontend": "npm run electron:build",
    "desktop:build:backend": "node scripts/build-backend.mjs",
    "desktop:prepare": "npm run desktop:build:frontend && npm run desktop:build:backend",
    "desktop:preflight": "node scripts/desktop-preflight.mjs",
    "desktop:dist:win": "npm run desktop:prepare && npm run desktop:preflight && node scripts/run-electron-builder.mjs --win --x64"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@sentry/react": "^10.53.1",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^1.1.7",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^25.7.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.8.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "eslint": "$eslint"
  },
  "build": {
    "appId": "com.nezhin.pos",
    "productName": "Nezhin POS",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "${env.NEZHIN_BUILD_OUTPUT}"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/prisma",
        "to": "backend/prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/*.{md,markdown,map,ts}",
          "!**/test/**",
          "!**/tests/**",
          "!**/.bin/**"
        ]
      },
      {
        "from": "../desktop-runtime/postgres",
        "to": "postgres-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://example.com/stock-pos-desktop-updates/"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    }
  }
}
