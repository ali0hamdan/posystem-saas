{
  "name": "nezhin-pos",
  "description": "Nezhin POS desktop application",
  "author": "Nezhin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons:ico": "node scripts/generate-icon.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build",
    "electron:pack": "npm run electron:build && electron-builder --dir",
    "electron:dist:win": "npm run electron:build && electron-builder --win --x64",
    "electron:dist:mac": "npm run electron:build && electron-builder --mac",
    "electron:dist:linux": "npm run electron:build && electron-builder --linux",
    "electron:dist": "npm run electron:build && electron-builder --win --x64"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/react": "^10.53.1",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^1.1.7",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.40.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^25.7.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.8.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "eslint": "$eslint"
  },
  "build": {
    "appId": "com.nezhin.pos",
    "productName": "Nezhin POS",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://example.com/stock-pos-desktop-updates/"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
