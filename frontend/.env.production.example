# Copied to `.env.production` for release builds (Vite reads it during `vite build`).
# Required for the packaged desktop app to call your live API (not localhost).

VITE_API_URL=https://api.example.com

# Optional branding
# VITE_STORE_NAME=Nezhin POS

# --- SaaS Super Admin URL hardening (anti-discovery) ---
# REQUIRED in production: do not ship the well-known /saas paths.
# Choose a long, random, opaque value. Treat as confidential.
# Both must match (frontend URL prefix + backend API prefix). They may
# differ if you want to confuse pattern scanners further.
VITE_SUPER_ADMIN_BASE_PATH=/nz-control-CHANGE-ME
VITE_SUPER_ADMIN_API_PREFIX=/saas-admin-api-CHANGE-ME
