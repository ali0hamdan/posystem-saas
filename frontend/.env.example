# Copy to `.env` or `.env.local` for local overrides. Never commit real secrets.

# Backend API origin (no trailing slash). Required for production builds pointing at your API.
# Development: defaults to http://localhost:3000 if unset.
VITE_API_URL=http://localhost:3000

# Optional: receipt header fallback when store settings are not loaded.
# VITE_STORE_NAME=Stock POS

# Optional: feature flag (see src/lib/env.ts).
# VITE_CASHIER_CAN_VIEW_STOCK_MOVEMENTS=true

# Local dev: skip license activation UI and client-side license checks (must match backend BYPASS_LICENSE for a smooth dev loop).
# VITE_BYPASS_LICENSE=true

# Optional: browser Sentry (leave unset to disable).
# VITE_SENTRY_DSN=

# Optional: when using `npm run electron:dev`, the shell loads this URL (default http://127.0.0.1:5173).
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173
